-- ===== RUBBERBAND DETECTION LOOP =====
local function startRubberbandDetection()
    local lastPosition = nil
    local lastTime = tick()
    
    spawn(function()
        while true do
            task.wait(0.05)
            
            local char = me.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local currentPos = char.HumanoidRootPart.Position
                
                if lastPosition and desyncActive then
                    local distance = (currentPos - lastPosition).Magnitude
                    local timeDiff = tick() - lastTime
                    
                    if distance > 15 and timeDiff < 0.15 then
                        rubberbandCount = rubberbandCount + 1
                        rubberbandLabel.Text = "Lag-backs: " .. rubberbandCount
                        
                        -- Update server position to rubberband spot
                        lastServerPos = currentPos
                        
                        if desyncWorldDot then
                            desyncWorldDot.Position = currentPos
                            
                            -- Flash effect
                            local original = desyncWorldDot.Color
                            desyncWorldDot.Color = Color3.fromRGB(255, 100, 0)
                            task.wait(0.05)
                            desyncWorldDot.Color = Color3.fromRGB(255, 255, 0)
                            task.wait(0.05)
                            desyncWorldDot.Color = original
                        end
                        
                        updateStatus("Lag-back #" .. rubberbandCount, Color3.fromRGB(255, 165, 0))
                        task.wait(0.3)
                    end
                end
                
                lastPosition = currentPos
                lastTime = tick()
            else
                lastPosition = nil
                task.wait(0.5)
            end
        end
    end)
end

-- ===== UPDATE LOOP FOR DISTANCE =====
local function startDistanceUpdate()
    spawn(function()
        while screenGui and screenGui.Parent do
            task.wait(0.2)
            
            if desyncActive and desyncWorldDot then
                local char = me.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    local dist = (char.HumanoidRootPart.Position - desyncWorldDot.Position).Magnitude
                    distanceStatus.Text = "Distance: " .. math.floor(dist) .. " studs"
                    
                    if dist > 15 then
                        distanceStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
                    elseif dist > 8 then
                        distanceStatus.TextColor3 = Color3.fromRGB(255, 200, 80)
                    else
                        distanceStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
                    end
                end
            end
        end
    end)
end

