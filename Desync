-- ===== DESYNC METHODS =====
local function tryDesyncMethod1()
    if raknet and raknet.desync then
        local success = pcall(function()
            raknet.desync(true)
            if raknet.setping then raknet.setping(9999) end
            if raknet.blockpacket then raknet.blockpacket(0x83, true) end
        end)
        if success then
            currentMethod = "RakNet.desync"
            return true
        end
    end
    return false
end

local function tryDesyncMethod2()
    if raknet and raknet.hook then
        local success = pcall(function()
            raknet.hook(true)
        end)
        if success then
            currentMethod = "RakNet.hook"
            return true
        end
    end
    return false
end

local function tryDesyncMethod3()
    if Desync and Desync.hook then
        local success = pcall(function()
            Desync.hook(true)
        end)
        if success then
            currentMethod = "Desync.hook"
            return true
        end
    end
    return false
end

local function tryDesyncMethod4()
    if raknet and raknet.send then
        local success = pcall(function()
            raknet.send(0x83, "desync_payload")
        end)
        if success then
            currentMethod = "RakNet.send"
            return true
        end
    end
    return false
end

local function tryDesyncMethod5()
    local success = pcall(function()
        local network = game:GetService("NetworkClient")
        if network and network.SetSimulationRadius then
            network:SetSimulationRadius(0)
        end
    end)
    if success then
        currentMethod = "Network Manipulation"
        return true
    end
    return false
end

-- ===== ENABLE DESYNC WITH FALLBACKS =====
local function enableDesync()
    if desyncActive then
        updateStatus("Already enabled", Color3.fromRGB(255, 165, 0))
        return true
    end
    
    updateStatus("Trying methods...", Color3.fromRGB(255, 200, 0))
    statusDot.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
    
    -- Freeze current position as server position
    local char = me.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        lastServerPos = char.HumanoidRootPart.Position
    end
    
    -- Try each method in order
    local success = false
    
    if tryDesyncMethod1() then
        success = true
    elseif tryDesyncMethod2() then
        success = true
    elseif tryDesyncMethod3() then
        success = true
    elseif tryDesyncMethod4() then
        success = true
    elseif tryDesyncMethod5() then
        success = true
    end
    
    if success then
        desyncActive = true
        rubberbandCount = 0
        
        -- Create white ball at server position
        if lastServerPos then
            desyncWorldDot, desyncBillboard, desyncDistanceLabel = createWhiteBall(lastServerPos, "DesyncMarker")
        end
        
        -- Start update loop
        dotUpdateConnection = RunService.RenderStepped:Connect(function()
            updateBallPosition()
            updateDistanceText()
            
            -- Update distance in status
            if desyncWorldDot and char and char:FindFirstChild("HumanoidRootPart") then
                local dist = (char.HumanoidRootPart.Position - desyncWorldDot.Position).Magnitude
                distanceStatus.Text = "Distance: " .. math.floor(dist) .. " studs"
                if dist > 15 then
                    distanceStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
                elseif dist > 8 then
                    distanceStatus.TextColor3 = Color3.fromRGB(255, 200, 80)
                else
                    distanceStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
                end
            end
        end)
        
        statusLabel.Text = "Desync: ON"
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        methodLabel.Text = "Method: " .. currentMethod
        methodLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        rubberbandLabel.Text = "Lag-backs: 0"
        rubberbandLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
        desyncBtn.Text = "DISABLE DESYNC"
        desyncBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 50)
        statusDot.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        updateStatus("Active - " .. currentMethod, Color3.fromRGB(0, 255, 100))
        
        -- Freeze character movement
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid.WalkSpeed = 0
            char.Humanoid.JumpPower = 0
        end
        
        return true
    else
        -- ALL METHODS FAILED
        updateStatus("FAILED - No method available", Color3.fromRGB(255, 50, 50))
        statusLabel.Text = "Desync: ERROR"
        statusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        methodLabel.Text = "Method: None"
        methodLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        statusDot.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        
        -- Create error message on top left (blinking)
        local errorFrame = Instance.new("Frame")
        errorFrame.Size = UDim2.new(0, 250, 0, 40)
        errorFrame.Position = UDim2.new(0, 10, 0, 80)
        errorFrame.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        errorFrame.BackgroundTransparency = 0.2
        errorFrame.BorderSizePixel = 0
        errorFrame.Parent = screenGui
        
        local errorCorner = Instance.new("UICorner")
        errorCorner.CornerRadius = UDim.new(0, 6)
        errorCorner.Parent = errorFrame
        
        local errorText = Instance.new("TextLabel")
        errorText.Size = UDim2.new(1, -10, 1, 0)
        errorText.Position = UDim2.new(0, 5, 0, 0)
        errorText.BackgroundTransparency = 1
        errorText.Text = "⚠️ Desync Failed - No method available!"
        errorText.TextColor3 = Color3.fromRGB(255, 255, 255)
        errorText.TextSize = 11
        errorText.Font = Enum.Font.GothamBold
        errorText.TextXAlignment = Enum.TextXAlignment.Left
        errorText.Parent = errorFrame
        
        -- Blink effect
        local blink = true
        local blinkConnection
        blinkConnection = RunService.RenderStepped:Connect(function()
            blink = not blink
            if blink then
                errorFrame.BackgroundTransparency = 0.2
            else
                errorFrame.BackgroundTransparency = 0.6
            end
        end)
        
        -- Auto remove after 5 seconds
        task.spawn(function()
            task.wait(5)
            if blinkConnection then blinkConnection:Disconnect() end
            errorFrame:Destroy()
        end)
        
        return false
    end
end

-- ===== DISABLE DESYNC =====
local function disableDesync()
    if not desyncActive then return end
    
    -- Try all disable methods
    if raknet and raknet.desync then
        pcall(function() raknet.desync(false) end)
    end
    if raknet and raknet.hook then
        pcall(function() raknet.hook(false) end)
    end
    if Desync and Desync.hook then
        pcall(function() Desync.hook(false) end)
    end
    if raknet and raknet.setping then
        pcall(function() raknet.setping(nil) end)
    end
    if raknet and raknet.blockpacket then
        pcall(function() raknet.blockpacket(0x83, false) end)
    end
    pcall(function()
        local network = game:GetService("NetworkClient")
        if network and network.SetSimulationRadius then
            network:SetSimulationRadius(16)
        end
    end)
    
    desyncActive = false
    
    -- Remove white ball
    if desyncWorldDot then
        desyncWorldDot:Destroy()
        desyncWorldDot = nil
    end
    
    if dotUpdateConnection then
        dotUpdateConnection:Disconnect()
        dotUpdateConnection = nil
    end
    
    statusLabel.Text = "Desync: OFF"
    statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    methodLabel.Text = "Method: " .. currentMethod
    methodLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    desyncBtn.Text = "ENABLE DESYNC"
    desyncBtn.BackgroundColor3 = Color3.fromRGB(255, 140, 0)
    statusDot.BackgroundColor3 = Color3.fromRGB(255, 165, 0)
    distanceStatus.Text = "Distance: 0 studs"
    distanceStatus.TextColor3 = Color3.fromRGB(150, 150, 150)
    updateStatus("Disabled", Color3.fromRGB(255, 165, 0))
    
    -- Restore character movement
    local char = me.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = 16
        char.Humanoid.JumpPower = 50
    end
end

