-- ===== CREATE WHITE BALL (Same as CocoX TP) =====
local function createWhiteBall(position, name)
    local ball = Instance.new("Part")
    ball.Name = name or "DesyncMarker"
    ball.Shape = Enum.PartType.Ball
    ball.Size = Vector3.new(2.5, 2.5, 2.5)
    ball.Material = Enum.Material.Neon
    ball.Color = Color3.fromRGB(255, 255, 255)
    ball.Anchored = true
    ball.CanCollide = false
    ball.CastShadow = false
    ball.Transparency = 0
    ball.Position = position
    ball.Parent = Workspace
    
    -- X-Ray effect (visible through walls)
    local highlight = Instance.new("Highlight")
    highlight.FillColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.2
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineTransparency = 0
    highlight.Parent = ball
    
    -- Billboard with distance
    local billboard = Instance.new("BillboardGui", ball)
    billboard.Size = UDim2.new(0, 80, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    
    local distanceNumber = Instance.new("TextLabel", billboard)
    distanceNumber.Size = UDim2.new(1, 0, 1, 0)
    distanceNumber.BackgroundTransparency = 1
    distanceNumber.TextColor3 = Color3.fromRGB(255, 255, 255)
    distanceNumber.TextStrokeTransparency = 0
    distanceNumber.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    distanceNumber.Font = Enum.Font.GothamBold
    distanceNumber.TextScaled = true
    distanceNumber.Text = "0"
    
    return ball, billboard, distanceNumber, highlight
end

-- ===== UPDATE BALL POSITION =====
local function updateBallPosition()
    if not desyncWorldDot then return end
    if lastServerPos then
        desyncWorldDot.Position = lastServerPos
    end
end

-- ===== UPDATE DISTANCE TEXT =====
local function updateDistanceText()
    if not desyncWorldDot or not desyncDistanceLabel then return end
    
    local char = me.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local dist = (char.HumanoidRootPart.Position - desyncWorldDot.Position).Magnitude
        desyncDistanceLabel.Text = math.floor(dist) .. " studs"
        
        if dist > 15 then
            desyncDistanceLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        elseif dist > 8 then
            desyncDistanceLabel.TextColor3 = Color3.fromRGB(255, 200, 80)
        else
            desyncDistanceLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        end
    end
end

-- ===== DETECT RUBBERBAND/LAG-BACK =====
local function detectRubberband()
    local lastPosition = nil
    local lastTime = tick()
    
    spawn(function()
        while true do
            task.wait(0.05)
            
            local char = me.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local currentPos = char.HumanoidRootPart.Position
                
                if lastPosition then
                    local distance = (currentPos - lastPosition).Magnitude
                    local timeDiff = tick() - lastTime
                    
                    if distance > 15 and timeDiff < 0.15 and desyncActive then
                        rubberbandCount = rubberbandCount + 1
                        
                        -- Update server position to rubberband spot
                        lastServerPos = currentPos
                        
                        if desyncWorldDot then
                            desyncWorldDot.Position = currentPos
                            
                            -- Flash effect
                            local original = desyncWorldDot.Color
                            desyncWorldDot.Color = Color3.fromRGB(255, 100, 0)
                            task.wait(0.05)
                            desyncWorldDot.Color = Color3.fromRGB(255, 255, 0)
                            task.wait(0.05)
                            desyncWorldDot.Color = original
                        end
                        
                        -- Update status
                        updateStatus("Rubberband #" .. rubberbandCount, Color3.fromRGB(255, 165, 0))
                        
                        task.wait(0.3)
                    end
                end
                
                lastPosition = currentPos
                lastTime = tick()
            else
                lastPosition = nil
                task.wait(0.5)
            end
        end
    end)
end

