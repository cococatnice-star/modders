                elseif dist > 8 then
                    label.TextColor3 = Color3.fromRGB(255, 200, 80)
                else
                    label.TextColor3 = Color3.fromRGB(255, 255, 255)
                end
            end
        end
    end
end

-- ===== DETECT RUBBERBAND WITH COUNTER =====
local function detectRubberband()
    local lastPosition = nil
    local lastTime = tick()
    
    spawn(function()
        while true do
            task.wait(0.05)
            
            local char = me.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local currentPos = char.HumanoidRootPart.Position
                
                if lastPosition then
                    local distance = (currentPos - lastPosition).Magnitude
                    local timeDiff = tick() - lastTime
                    
                    if distance > 15 and timeDiff < 0.15 and desyncActive then
                        rubberbandCount = rubberbandCount + 1
                        
                        if rubberbandCount % 5 == 0 and rubberbandCount < 10 then
                            createNotification("⚠️ Lag Warning", "Rubberband #" .. rubberbandCount .. " | Desync becoming unstable", "warning", 2)
                        end
                        
                        if rubberbandCount == 8 then
                            createNotification("⚠️ Critical Lag", "2 more rubberbands until action required", "rubberband", 2.5)
                        elseif rubberbandCount == 9 then
                            createNotification("⚠️ Final Warning", "1 more rubberband and desync will be disabled", "rubberband", 2.5)
                        end
                        
                        if rubberbandCount >= 10 and not rubberbandWarningShown then
                            rubberbandWarningShown = true
                            createNotification("⚠️ Heavy Lag Detected", "Opening confirmation dialog...", "warning", 2)
                            task.wait(0.5)
                            showConfirmationDialog()
                        end
                        
                        lastServerPos = currentPos
                        
                        if desyncWorldDot then
                            desyncWorldDot.Position = currentPos
                            playSound("rubberband")
                            
                            local flashColor = Color3.fromRGB(255, 100, 0)
                            if rubberbandCount >= 8 then
                                flashColor = Color3.fromRGB(255, 0, 0)
                            end
                            
                            local original = desyncWorldDot.Color
                            desyncWorldDot.Color = flashColor
                            task.wait(0.05)
                            desyncWorldDot.Color = Color3.fromRGB(255, 255, 0)
                            task.wait(0.05)
                            desyncWorldDot.Color = original
                        end
                        
                        createNotification("🌀 Rubberband #" .. rubberbandCount, "Desync ball moved to new position", "rubberband", 2)
                        task.wait(0.3)
                    end
                end
                
                lastPosition = currentPos
                lastTime = tick()
            else
                lastPosition = nil
                task.wait(0.5)
            end
        end
    end)
end

-- ===== DESYNC FUNCTIONS =====
local function freezeServerPosition()
    local char = me.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        lastServerPos = char.HumanoidRootPart.Position
    end
end

local function enableDesync()
    if desyncActive then return true end
    
    freezeServerPosition()
    
    local success, methodUsed = enableDesyncWithFallback()
    
    if not success then
        createNotification("❌ Error", "No desync method available! Make sure you have a working executor.", "error", 4)
        return false
    end
    
    playSound("enable")
    currentDesyncMethod = methodUsed
    
    rubberbandCount = 0
    rubberbandWarningShown = false
    
    if not desyncWorldDot then
        desyncWorldDot, desyncBillboard, desyncDistanceLabel = createWorldWhiteBall(lastServerPos, "DesyncWhiteBall")
    else
        desyncWorldDot.Position = lastServerPos
        desyncWorldDot.Visible = true
    end
    
    desyncActive = true
    
    desyncConnection = RunService.RenderStepped:Connect(function()
        updateDesyncBallPosition()
        updateDesyncDistance()
    end)
    
    local char = me.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = 0
        char.Humanoid.JumpPower = 0
    end
    
    createNotification("🔴 Desync ENABLED", "Using: " .. methodUsed .. " | Lag counter: 0/10", "desync_on", 4)
    print("[Desync] Enabled using method: " .. methodUsed)
    return true
end

local function disableDesync()
    if not desyncActive then return end
    
    playSound("disable")
    
    disableDesyncWithFallback()
    
    desyncActive = false
    
    if desyncWorldDot then
        desyncWorldDot.Visible = false
    end
    
    if desyncConnection then
        desyncConnection:Disconnect()
        desyncConnection = nil
    end
    
    local char = me.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = 16
        char.Humanoid.JumpPower = 50
        char.Humanoid.PlatformStand = false
    end
    
    createNotification("⭕ Desync DISABLED", "White ball hidden | Movement restored", "desync_off", 3)
end

local function toggleDesync()
    if desyncActive then
        disableDesync()
    else
        enableDesync()
    end
end

