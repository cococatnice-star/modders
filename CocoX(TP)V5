local function updateSavePosDistance()
    if not savedPosMarker or not savedPosMarker.Parent then return end
    
    local billboard = savedPosMarker:FindFirstChildOfClass("BillboardGui")
    if billboard then
        local label = billboard:FindFirstChildOfClass("TextLabel")
        if label then
