-- ===== AUTO PATHING VARIABLES =====
local autoActive = false
local autoDirection = nil
local currentWaypointIndex = 1
local autoConnection = nil
local currentTargetPos = nil
local moveTween = nil

-- ===== AUTO PATH FUNCTIONS =====
local function moveToPosition(targetPos)
    local char = me.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    if moveTween then
        moveTween:Cancel()
        moveTween = nil
    end
    
    local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    moveTween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(targetPos)})
    moveTween:Play()
    
    moveTween.Completed:Connect(function()
        moveTween = nil
    end)
    
    return true
end

local function startAutoPath(direction)
    if autoActive then
        stopAutoPath()
    end
    
    autoDirection = direction
    currentWaypointIndex = 1
    autoActive = true
    
    local waypoints = (direction == "right") and rightWaypoints or leftWaypoints
    
    if #waypoints == 0 then
        createNotification("❌ Error", "No waypoints found for " .. direction, "error", 2)
        autoActive = false
        return
    end
    
    createNotification("🚶 Auto " .. direction:upper(), "Starting auto path movement", "success", 2)
    playSound("enable")
    
    currentTargetPos = waypoints[currentWaypointIndex]
    moveToPosition(currentTargetPos)
    
    autoConnection = RunService.RenderStepped:Connect(function()
        if not autoActive then return end
        
        local char = me.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local waypoints = (autoDirection == "right") and rightWaypoints or leftWaypoints
        local targetPos = waypoints[currentWaypointIndex]
        
        if not targetPos then
            currentWaypointIndex = 1
            targetPos = waypoints[1]
        end
        
        local distance = (hrp.Position - targetPos).Magnitude
        
        if distance < 5 then
            currentWaypointIndex = currentWaypointIndex + 1
            if currentWaypointIndex > #waypoints then
                currentWaypointIndex = 1
                createNotification("🔄 Loop", "Completed loop, starting over", "info", 1)
            end
            
            local nextTarget = waypoints[currentWaypointIndex]
            if nextTarget then
                currentTargetPos = nextTarget
                moveToPosition(currentTargetPos)
                createNotification("📍 Waypoint", "Moving to waypoint " .. currentWaypointIndex .. " of " .. #waypoints, "info", 1)
            end
        end
    end)
end

local function stopAutoPath()
    if not autoActive then return end
    
    autoActive = false
    if autoConnection then
        autoConnection:Disconnect()
        autoConnection = nil
    end
    
    if moveTween then
        moveTween:Cancel()
        moveTween = nil
    end
    
    autoDirection = nil
    currentWaypointIndex = 1
    currentTargetPos = nil
    
    createNotification("⭕ Auto Stopped", "Auto path movement stopped", "desync_off", 2)
    playSound("disable")
end

local function toggleAutoRight()
    if autoActive and autoDirection == "right" then
        stopAutoPath()
    else
        startAutoPath("right")
    end
end

local function toggleAutoLeft()
    if autoActive and autoDirection == "left" then
        stopAutoPath()
    else
        startAutoPath("left")
    end
end

