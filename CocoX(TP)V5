-- ===== TELEPORT FUNCTIONS =====
local function teleportToSaved()
    if not savedPos then
        playSound("error")
        createNotification("⚠️ No Position Saved", "Save a position first before teleporting", "warning", 2.5)
        return
    end
    
    playSound("teleport")
    
    local char = me.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    if mode == "Smooth" then
        createNotification("✨ Teleporting", "Moving smoothly to saved position...", "teleport", 2)
        spawn(function()
            local startPos = hrp.Position
            local distance = (savedPos - startPos).Magnitude
            local duration = math.min(distance / 80, 2)
            local startTime = tick()
            while tick()-startTime < duration do
                local alpha = (tick()-startTime)/duration
                hrp.CFrame = CFrame.new(startPos:Lerp(savedPos, alpha))
                RunService.RenderStepped:Wait()
            end
            hrp.CFrame = CFrame.new(savedPos)
            playSound("success")
            createNotification("✅ Teleport Complete", "You have arrived at saved position", "success", 2)
        end)
    else
        hrp.CFrame = CFrame.new(savedPos)
        playSound("success")
        createNotification("⚡ Teleport Complete", "Instant teleport to saved position", "teleport", 2)
    end
end

