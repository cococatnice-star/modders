-- ===== DESYNC WITH FALLBACK (raknet.desync -> raknet.hook) =====
local function enableDesyncWithFallback()
    local success = false
    local methodUsed = "None"
    
    -- Try 1: raknet.desync
    if raknet and raknet.desync then
        local worked = pcall(function()
            raknet.desync(true)
            if raknet.setping then raknet.setping(9999) end
            if raknet.blockpacket then raknet.blockpacket(0x83, true) end
        end)
        if worked then
            success = true
            methodUsed = "RakNet.desync"
            print("[Desync] Using raknet.desync method")
        end
    end
    
    -- Try 2: raknet.hook (fallback if desync not available)
    if not success and raknet and raknet.hook then
        local worked = pcall(function()
            raknet.hook(true)
        end)
        if worked then
            success = true
            methodUsed = "RakNet.hook"
            print("[Desync] Using raknet.hook method (fallback)")
        end
    end
    
    -- Try 3: Desync.hook (alternative executor)
    if not success and Desync and Desync.hook then
        local worked = pcall(function()
            Desync.hook(true)
        end)
        if worked then
            success = true
            methodUsed = "Desync.hook"
            print("[Desync] Using Desync.hook method (second fallback)")
        end
    end
    
    -- Try 4: raknet.send packet method
    if not success and raknet and raknet.send then
        local worked = pcall(function()
            raknet.send(0x83, "desync_payload")
            raknet.send(0x84, "sync_break")
        end)
        if worked then
            success = true
            methodUsed = "RakNet.send"
            print("[Desync] Using raknet.send method (third fallback)")
        end
    end
    
    -- Try 5: Network manipulation (last resort)
    if not success then
        local worked = pcall(function()
            local network = game:GetService("NetworkClient")
            if network and network.SetSimulationRadius then
                network:SetSimulationRadius(0)
            end
            if settings().Network and settings().Network.IncomingReplicationLag then
                settings().Network.IncomingReplicationLag = 9999
            end
        end)
        if worked then
            success = true
            methodUsed = "Network Manipulation"
            print("[Desync] Using network manipulation (last resort)")
        end
    end
    
    return success, methodUsed
end

local function disableDesyncWithFallback()
    -- Try raknet.desync false
    if raknet and raknet.desync then
        pcall(function() raknet.desync(false) end)
    end
    
    -- Try raknet.hook false
    if raknet and raknet.hook then
        pcall(function() raknet.hook(false) end)
    end
    
    -- Try Desync.hook false
    if Desync and Desync.hook then
        pcall(function() Desync.hook(false) end)
    end
    
    -- Reset network
    pcall(function()
        if raknet and raknet.setping then raknet.setping(nil) end
        if raknet and raknet.blockpacket then raknet.blockpacket(0x83, false) end
        
        local network = game:GetService("NetworkClient")
        if network and network.SetSimulationRadius then
            network:SetSimulationRadius(16)
        end
        
        if settings().Network and settings().Network.IncomingReplicationLag then
            settings().Network.IncomingReplicationLag = 0
        end
    end)
end

