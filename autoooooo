-- ============================================
-- FETCH MESSAGES USING EXECUTOR REQUEST()
-- ============================================
local function FetchAndProcessMessages()
    local success, response = pcall(function()
        return request({
            Url = API_URL .. "?t=" .. tick(),
            Method = "GET"
        })
    end)

    if not success then
        StatusLabel.Text = "⚠️ Cannot reach API"
        StatusDot.BackgroundColor3 = Colors.Error
        print("❌ Request failed:", response)
        return
    end

    if response.StatusCode ~= 200 then
        StatusLabel.Text = "⚠️ API error: " .. tostring(response.StatusCode)
        StatusDot.BackgroundColor3 = Colors.Error
        return
    end

    local success2, data = pcall(function()
        return HttpService:JSONDecode(response.Body)
    end)

    if not success2 then
        print("❌ Failed to parse JSON:", response.Body)
        return
    end

    local messages = {}
    if type(data) == "table" then
        if #data > 0 then
            messages = data
        elseif data.messages then
            messages = data.messages
        elseif data.data then
            messages = data.data
        elseif data.content or data.message then
            messages = {data}
        end
    end

    for _, msg in ipairs(messages) do
        local msgId = tostring(msg.id or msg.timestamp or msg.time or os.time())
        if not ProcessedMessages[msgId] then
            ProcessedMessages[msgId] = true
            local content = msg.content or msg.message or ""
            local serverId = msg.serverId or msg.server_id or ExtractServerId(content)
            if content ~= "" then
                local brainrots = ParseBrainrotFromMessage(content)
                for _, br in ipairs(brainrots) do
                    AddBrainrotToGUI(br.name, br.value, serverId)
                end
                if #brainrots > 0 then
                    StatusLabel.Text = "📨 New brainrot detected!"
                    StatusDot.BackgroundColor3 = Colors.PrimaryLight
                    task.wait(0.5)
                    StatusDot.BackgroundColor3 = Colors.Success
                end
            end
        end
    end
end

-- ============================================
-- POLLING LOOP
-- ============================================
task.spawn(function()
    while true do
        FetchAndProcessMessages()
        task.wait(POLL_INTERVAL)
    end
end)

