-- ============================================
-- PARSE BRAINROT FROM MESSAGE
-- ============================================
local function ParseBrainrotFromMessage(content)
    local results = {}
    for name, value in string.gmatch(content, "%*%*([^%*]+)%*%*%s*-%s*([%$]?[%d%.]+[KMGT]?)") do
        local cleanName = name:gsub("^%s*", ""):gsub("%s*$", "")
        if cleanName ~= "" and cleanName ~= "🧠 BRAINROT FOUND!" and #cleanName > 2 then
            table.insert(results, {name = cleanName, value = value})
        end
    end
    for name, value in string.gmatch(content, "([^%-]+)%s*-%s*([%$]?[%d%.]+[KMGT]?)") do
        local cleanName = name:gsub("^%s*", ""):gsub("%s*$", "")
        if cleanName ~= "" and #cleanName > 2 and not cleanName:match("BRAINROT") then
            local alreadyAdded = false
            for _, r in ipairs(results) do
                if r.name == cleanName then alreadyAdded = true break end
            end
            if not alreadyAdded then
                table.insert(results, {name = cleanName, value = value})
            end
        end
    end
    for name, value in string.gmatch(content, "([A-Za-z%s]+)%s+([%$]?[%d%.]+[KMGT]?)") do
        local cleanName = name:gsub("^%s*", ""):gsub("%s*$", "")
        if cleanName ~= "" and #cleanName > 3 and not cleanName:match("BRAINROT") and not cleanName:match("Owner") then
            local alreadyAdded = false
            for _, r in ipairs(results) do
                if r.name == cleanName then alreadyAdded = true break end
            end
            if not alreadyAdded then
                table.insert(results, {name = cleanName, value = value})
            end
        end
    end
    return results
end

local function ExtractServerId(content)
    local serverMatch = string.match(content, "`([^`]+)`")
    return serverMatch or game.JobId
end

local function getBrainrotColor(name)
    if name:find("Gold") then return Colors.Gold end
    if name:find("Rainbow") then return Colors.Rainbow end
    if name:find("Dragon") then return Color3.fromRGB(255, 100, 50) end
    if name:find("Matteo") then return Color3.fromRGB(255, 100, 100) end
    if name:find("Cocofanto") then return Color3.fromRGB(255, 150, 50) end
    return Colors.Text
end

