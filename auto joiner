-- POLL LOOP — real-time only
-- ============================================
task.spawn(function()
    while true do
        local body = httpGet(API_URL .. "?t=" .. tick())
        if not body then
            StatusLabel.Text = "⚠️ No response"
            StatusDot.BackgroundColor3 = Colors.Error
        else
            local ok, data = pcall(HttpService.JSONDecode, HttpService, body)
            if not ok then
                StatusLabel.Text = "⚠️ Parse error"
            else
                if type(data) == "table" then
                    if firstPoll then
                        for _, item in ipairs(data) do
                            local id = tostring(item.id or item.timestamp or "")
                            if id ~= "" then Seen[id] = true end
                        end
                        firstPoll = false
                        StatusLabel.Text = "🟢 Live"
                        StatusDot.BackgroundColor3 = Colors.Success
                        print("[CocoX] Ready - watching for brainrots")
                    else
                        local newCount = 0
                        for _, item in ipairs(data) do
                            local id = tostring(item.id or item.timestamp or "")
                            if id ~= "" and not Seen[id] then
                                Seen[id] = true
                                addRow(
                                    tostring(item.name  or "Unknown"),
                                    tostring(item.value or "$?"),
                                    tostring(item.owner or "?"),
                                    tostring(item.jobId or "")
                                )
                                newCount = newCount + 1
                            end
                        end
                        if newCount > 0 then
                            StatusLabel.Text = "📨 " .. newCount .. " new!"
                            StatusDot.BackgroundColor3 = Colors.PrimaryLight
                            task.wait(0.5)
                            StatusDot.BackgroundColor3 = Colors.Success
                        else
                            StatusLabel.Text = "🟢 Watching (" .. totalCount .. ")"
                            StatusDot.BackgroundColor3 = Colors.Success
                        end
                    end
                end
            end
        end
        task.wait(POLL_INTERVAL)
    end
end)

