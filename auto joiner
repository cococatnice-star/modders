-- ============================================
-- WORKING SCANNER
-- ============================================
local function ScanCurrentServer()
    local foundBrainrots = {}
    
    if not SyncInt._data then
        return foundBrainrots
    end
    
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return foundBrainrots end
    
    for _, plot in ipairs(plots:GetChildren()) do
        local uid = plot.Name
        
        local ch = stealthGet(uid)
        if not ch then goto continue end
        
        local animalList = sProp(ch, "AnimalList")
        if not animalList then goto continue end
        
        local owner = sProp(ch, "Owner")
        if not owner or owner.UserId == LocalPlayer.UserId then goto continue end
        
        for slot, animalData in pairs(animalList) do
            if type(animalData) == "table" then
                local animalId = animalData.Index
                
                local animalInfo = AnimalsData and AnimalsData[animalId]
                if not animalInfo then goto next_animal end
                
                local genValue = 0
                if AnimalsShared then
                    genValue = AnimalsShared:GetGeneration(
                        animalId, 
                        animalData.Mutation, 
                        animalData.Traits, 
                        nil
                    ) or 0
                end
                
                if genValue < Config.MinValue then goto next_animal end
                
                local displayName = animalInfo.DisplayName or animalId
                local mutation = animalData.Mutation or "None"
                
                local fullName = displayName
                if mutation ~= "None" and mutation ~= "Normal" then
                    fullName = mutation .. " " .. displayName
                end
                
                -- Check against target list
                local isTarget = false
                for targetName, _ in pairs(Config.TargetBrainrots) do
                    if fullName:lower():find(targetName:lower()) or 
                       displayName:lower():find(targetName:lower()) then
                        isTarget = true
                        break
                    end
                end
                
                if isTarget then
                    table.insert(foundBrainrots, {
                        name = displayName,
                        fullName = fullName,
                        mutation = mutation,
                        value = genValue,
                        owner = owner.Name,
                        plot = uid,
                        slot = tostring(slot)
                    })
                    
                    AddLog("🎯 FOUND: " .. fullName .. " | Value: $" .. tostring(genValue) .. "/s | Owner: " .. owner.Name)
                    
                    if Config.WebhookUrl ~= "" then
                        SendDiscordNotification(fullName, game.JobId, genValue)
                    end
                end
            end
            ::next_animal::
        end
        ::continue::
    end
    
    return foundBrainrots
end

local function CheckForTargets()
    local foundBrainrots = ScanCurrentServer()
    
    if #foundBrainrots > 0 then
        for _, brainrot in ipairs(foundBrainrots) do
            AddLog("✅ TARGET FOUND: " .. brainrot.fullName .. " (Value: $" .. tostring(brainrot.value) .. "/s)")
            StatusLabel.Text = "Status: TARGET FOUND - " .. brainrot.fullName
        end
        return true, foundBrainrots[1].fullName
    end
    
    return false, nil
end

-- ============================================
-- AUTO JOINER LOOP
-- ============================================
local autoJoinerRunning = false
local autoJoinerActive = false

local function StartAutoJoiner()
    if autoJoinerRunning then return end
    autoJoinerRunning = true
    
    AddLog("🚀 Auto Joiner started!")
    StatusLabel.Text = "Status: Running..."
    AutoJoinBtn.BackgroundColor3 = Colors.Error
    AutoJoinBtn.Text = "⏹ STOP AUTO JOINER"
    
    while autoJoinerRunning and autoJoinerActive do
        local found, name = CheckForTargets()
        
        if found then
            AddLog("🎉 Target found! Staying in server: " .. name)
            StatusLabel.Text = "Status: STAYING - " .. name
            task.wait(30)
        else
            AddLog("🔍 No targets found. Hopping to new server...")
            ServerHop()
            task.wait(Config.ServerHopDelay)
        end
        
        task.wait(Config.ScanInterval)
    end
end

local function StopAutoJoiner()
    autoJoinerRunning = false
    AddLog("🛑 Auto Joiner stopped")
    StatusLabel.Text = "Status: Idle"
    AutoJoinBtn.BackgroundColor3 = Colors.Primary
    AutoJoinBtn.Text = "▶ START AUTO JOINER"
end

AutoJoinBtn.MouseButton1Click:Connect(function()
    autoJoinerActive = not autoJoinerActive
    Config.AutoJoinEnabled = autoJoinerActive
    
    if autoJoinerActive then
        local selectedCount = 0
        for _ in pairs(Config.TargetBrainrots) do selectedCount = selectedCount + 1 end
        if selectedCount == 0 then
            AddLog("⚠ Please select at least one brainrot target!", true)
            autoJoinerActive = false
            return
        end
        if not SyncInt._data then
            AddLog("⚠ Waiting for Synchronizer to load...", true)
        end
        StartAutoJoiner()
    else
        StopAutoJoiner()
    end
end)

