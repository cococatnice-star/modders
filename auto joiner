    AddLog("🥭 CocoX Auto Join Private Loading...")
    
    -- Load Synchronizer
    for i = 1, 10 do
        SyncInt._data = getInternalTable()
        if SyncInt._data then break end
        task.wait(1)
    end
    
    if SyncInt._data then
        AddLog("✅ Synchronizer loaded", false)
    else
        AddLog("⚠ Synchronizer failed to load", true)
    end
    
    -- Load game modules
    if Datas and Shared then
        for i = 1, 10 do
            local s1, d = pcall(require, Datas:FindFirstChild("Animals"))
            local s2, sh = pcall(require, Shared:FindFirstChild("Animals"))
            if s1 and d then AnimalsData = d end
            if s2 and sh then AnimalsShared = sh end
            if AnimalsData and AnimalsShared then break end
            task.wait(0.5)
        end
    end
    
    if AnimalsData and AnimalsShared then
        AddLog("✅ Game modules loaded - " .. #AllBrainrots .. " brainrots available", false)
    else
        AddLog("⚠ Game modules failed to load", true)
    end
    
    AddLog("📋 Go to BRAINROT LIST tab to select targets")
    AddLog("⚙ Select brainrots and click START to begin")
end)
