-- SAVE / LOAD
local function SaveFilters()
    local list = {}
    for name in pairs(SelectedFilters) do table.insert(list, name) end
    local ok = pcall(function()
        UniversalWriteFile(SAVE_FILE, HttpService:JSONEncode({selected=list, showAll=ShowAll, version=2}))
    end)
    StatusLabel.Text = ok and ("💾 Saved "..#list.." filters!") or "❌ Save failed!"
    task.wait(1.5); StatusLabel.Text = "🟢 Live"
end

local function LoadFilters()
    local ok, data = pcall(function()
        if not UniversalFileExists(SAVE_FILE) then return nil end
        local c = UniversalReadFile(SAVE_FILE)
        return (c and c ~= "") and HttpService:JSONDecode(c) or nil
    end)
    if ok and data then
        SelectedFilters = {}
        if data.selected then for _, n in ipairs(data.selected) do SelectedFilters[n]=true end end
        ShowAll = (data.showAll ~= nil) and data.showAll or (#(data.selected or {})==0)
    end
end

