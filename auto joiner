-- HTTP wrapper
local function httpGet(url)
    local reqFn = (syn and syn.request) or request or (http and http.request)
    if reqFn then
        local ok, res = pcall(reqFn, {Url=url, Method="GET"})
        if ok and res and res.Body and res.Body ~= "" then return res.Body end
    end
    local ok2, body = pcall(function() return HttpService:GetAsync(url, true) end)
    if ok2 and body and body ~= "" then return body end
    return nil
end

