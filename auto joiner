        else
            ref.checkbox.Text="□"; ref.checkbox.BackgroundColor3=Colors.PrimaryDark
            ref.checkbox.BackgroundTransparency=0.5; ref.label.TextColor3=Colors.TextDim
        end
    end
    local count=0; for _ in pairs(SelectedFilters) do count=count+1 end
    if count==0 then ShowAll=true; FilterIndicator.Text="🎯 Filter: ALL"; FilterIndicator.TextColor3=Colors.TextDim
    else ShowAll=false; FilterIndicator.Text="🎯 Filter: "..count.." selected"; FilterIndicator.TextColor3=Colors.PrimaryLight end
    StatusLabel.Text="📂 Filters loaded!"; task.wait(1); StatusLabel.Text="🟢 Live"
