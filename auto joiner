-- ============================================
local totalCount = 0
local Seen       = {}
local firstPoll  = true

local function getColor(name)
    if name:find("Gold")    then return Colors.Gold    end
    if name:find("Rainbow") then return Colors.Rainbow end
    return Colors.Text
end

local function addRow(name, value, owner, jobId)
    if not ShouldDisplay(name) then return end
    totalCount = totalCount + 1
    local color = getColor(name)

    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,0,0,40)
    row.BackgroundColor3 = Colors.PanelBg
    row.BackgroundTransparency = 0.5
    row.LayoutOrder = totalCount
    row.Parent = ListScroll
    Instance.new("UICorner",row).CornerRadius = UDim.new(0,5)

    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0,3,1,0)
    bar.BackgroundColor3 = color
    bar.BorderSizePixel = 0
    bar.Parent = row

    local lName = Instance.new("TextLabel")
    lName.Size=UDim2.new(0.42,-15,1,0); lName.Position=UDim2.new(0,12,0,0)
    lName.BackgroundTransparency=1; lName.Text=name; lName.TextColor3=color
    lName.TextSize=11; lName.Font=Enum.Font.GothamBold
    lName.TextXAlignment=Enum.TextXAlignment.Left
    lName.TextTruncate=Enum.TextTruncate.AtEnd; lName.Parent=row

    local lValue = Instance.new("TextLabel")
    lValue.Size=UDim2.new(0.18,0,1,0); lValue.Position=UDim2.new(0.42,0,0,0)
    lValue.BackgroundTransparency=1; lValue.Text=value; lValue.TextColor3=Colors.PrimaryLight
    lValue.TextSize=10; lValue.Font=Enum.Font.GothamBold
    lValue.TextXAlignment=Enum.TextXAlignment.Left; lValue.Parent=row

    local lOwner = Instance.new("TextLabel")
    lOwner.Size=UDim2.new(0.22,0,1,0); lOwner.Position=UDim2.new(0.60,0,0,0)
    lOwner.BackgroundTransparency=1; lOwner.Text=owner; lOwner.TextColor3=Colors.TextDim
    lOwner.TextSize=9; lOwner.Font=Enum.Font.Gotham
    lOwner.TextXAlignment=Enum.TextXAlignment.Left
    lOwner.TextTruncate=Enum.TextTruncate.AtEnd; lOwner.Parent=row

    -- ============================================
    -- FIXED JOIN BUTTON
    -- Uses TeleportToPlaceInstance to join the
    -- exact server where the brainrot was found
    -- ============================================
    local joinBtn = Instance.new("TextButton")
    joinBtn.Size = UDim2.new(0,62,0,32)
    joinBtn.Position = UDim2.new(1,-70,0.5,-16)
    joinBtn.BackgroundColor3 = Colors.Success
    joinBtn.BackgroundTransparency = 0.15
    joinBtn.Text = "⚡ JOIN"
    joinBtn.TextColor3 = Color3.fromRGB(0,0,0)
    joinBtn.TextSize = 11
    joinBtn.Font = Enum.Font.GothamBold
    joinBtn.BorderSizePixel = 0
    joinBtn.Parent = row
    Instance.new("UICorner",joinBtn).CornerRadius = UDim.new(0,5)

    joinBtn.MouseButton1Click:Connect(function()
        if jobId == "" or jobId == nil then
            StatusLabel.Text = "⚠️ No server ID — cannot join"
            return
        end

        StatusLabel.Text = "🚀 Joining server for: " .. name
        joinBtn.Text = "⌛"
        joinBtn.BackgroundColor3 = Colors.PrimaryLight

        task.spawn(function()
            local player = game.Players.LocalPlayer
            -- TeleportToPlaceInstance joins the exact server by job ID
            local ok, err = pcall(function()
                TeleportService:TeleportToPlaceInstance(game.PlaceId, jobId, player)
            end)
            if not ok then
                -- Fallback: try the older API just in case
                local ok2, err2 = pcall(function()
                    TeleportService:Teleport(game.PlaceId, jobId)
                end)
                if not ok2 then
                    StatusLabel.Text = "❌ Join failed: " .. tostring(err2)
                    joinBtn.Text = "⚡ JOIN"
                    joinBtn.BackgroundColor3 = Colors.Success
                end
            end
        end)
    end)

    CountLabel.Text = "📡 Brainrots: " .. totalCount
end

